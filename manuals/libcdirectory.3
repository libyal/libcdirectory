.Dd June 10, 2026
.Dt LIBCDIRECTORY 3
.Os
.Sh NAME
.Nm libcdirectory.h
.Nd Library to support cross-platform C directory functions
.Sh SYNOPSIS
.In libcdirectory.h
.Pp
Support functions
.nf
.Ft const char *
.Fo libcdirectory_get_version
.Fa "void"
.Fc
.fi
.nf
.Ft int
.Fo libcdirectory_get_codepage
.Fa "int *codepage"
.Fa "libcdirectory_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcdirectory_set_codepage
.Fa "int codepage"
.Fa "libcdirectory_error_t **error"
.Fc
.fi
.Pp
Error functions
.nf
.Ft void
.Fo libcdirectory_error_free
.Fa "libcdirectory_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcdirectory_error_fprint
.Fa "libcdirectory_error_t *error"
.Fa "FILE *stream"
.Fc
.fi
.nf
.Ft int
.Fo libcdirectory_error_sprint
.Fa "libcdirectory_error_t *error"
.Fa "char *string"
.Fa "size_t size"
.Fc
.fi
.nf
.Ft int
.Fo libcdirectory_error_backtrace_fprint
.Fa "libcdirectory_error_t *error"
.Fa "FILE *stream"
.Fc
.fi
.nf
.Ft int
.Fo libcdirectory_error_backtrace_sprint
.Fa "libcdirectory_error_t *error"
.Fa "char *string"
.Fa "size_t size"
.Fc
.fi
.Pp
Directory functions
.nf
.Ft int
.Fo libcdirectory_directory_initialize
.Fa "libcdirectory_directory_t **directory"
.Fa "libcdirectory_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcdirectory_directory_free
.Fa "libcdirectory_directory_t **directory"
.Fa "libcdirectory_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcdirectory_directory_open
.Fa "libcdirectory_directory_t *directory"
.Fa "const char *directory_name"
.Fa "libcdirectory_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcdirectory_directory_close
.Fa "libcdirectory_directory_t *directory"
.Fa "libcdirectory_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcdirectory_directory_read_entry
.Fa "libcdirectory_directory_t *directory"
.Fa "libcdirectory_directory_entry_t *directory_entry"
.Fa "libcdirectory_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcdirectory_directory_has_entry
.Fa "libcdirectory_directory_t *directory"
.Fa "libcdirectory_directory_entry_t *directory_entry"
.Fa "const char *entry_name"
.Fa "size_t entry_name_length"
.Fa "uint8_t entry_type"
.Fa "uint8_t compare_flags"
.Fa "libcdirectory_error_t **error"
.Fc
.fi
.Pp
Available when compiled with wide character string support:
.nf
.Ft int
.Fo libcdirectory_directory_open_wide
.Fa "libcdirectory_directory_t *directory"
.Fa "const wchar_t *directory_name"
.Fa "libcdirectory_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcdirectory_directory_has_entry_wide
.Fa "libcdirectory_directory_t *directory"
.Fa "libcdirectory_directory_entry_t *directory_entry"
.Fa "const wchar_t *entry_name"
.Fa "size_t entry_name_length"
.Fa "uint8_t entry_type"
.Fa "uint8_t compare_flags"
.Fa "libcdirectory_error_t **error"
.Fc
.fi
.Pp
Directory entry functions
.nf
.Ft int
.Fo libcdirectory_directory_entry_initialize
.Fa "libcdirectory_directory_entry_t **directory_entry"
.Fa "libcdirectory_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcdirectory_directory_entry_free
.Fa "libcdirectory_directory_entry_t **directory_entry"
.Fa "libcdirectory_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcdirectory_directory_entry_get_type
.Fa "libcdirectory_directory_entry_t *directory_entry"
.Fa "uint8_t *type"
.Fa "libcdirectory_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcdirectory_directory_entry_get_name
.Fa "libcdirectory_directory_entry_t *directory_entry"
.Fa "char **name"
.Fa "libcdirectory_error_t **error"
.Fc
.fi
.Pp
Available when compiled with wide character string support:
.nf
.Ft int
.Fo libcdirectory_directory_entry_get_name_wide
.Fa "libcdirectory_directory_entry_t *directory_entry"
.Fa "wchar_t **name"
.Fa "libcdirectory_error_t **error"
.Fc
.fi
.Sh DESCRIPTION
The
.Fn libcdirectory_get_version
function is used to retrieve the library version.
.Sh RETURN VALUES
Most of the functions return NULL or \-1 on error, dependent on the return \
type.
For the actual return values see
.In libcdirectory.h .
.Sh ENVIRONMENT
None
.Sh FILES
None
.Sh NOTES
libcdirectory can be compiled with wide character support (wchar_t).
.sp
To compile libcdirectory with wide character support use:
.Ar ./configure --enable-wide-character-type
 or define:
.Ar _UNICODE
 or
.Ar UNICODE
 during compilation.
.sp
.Ar LIBCDIRECTORY_WIDE_CHARACTER_TYPE
 in libcdirectory/features.h can be used to determine if libcdirectory was compiled with wide character support.
.Sh SEE ALSO
.In libcdirectory.h
